# ============================================================
# .env.india — Indian Stock Market AI Algo Trader Configuration
# Copy this file to .env.india and fill in your real values.
# NEVER commit .env.india to git.
# ============================================================

# ----------------------------------------------------------
# Dhan Broker Credentials (required)
# Get from: https://api.dhan.co/v2/ → Developer Kit
# ----------------------------------------------------------
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# ----------------------------------------------------------
# Strategy Universe
# Comma-separated NSE ticker symbols (no .NS suffix needed).
# Leave blank to use the DEFAULT_UNIVERSE (Nifty 50 top 20).
# ----------------------------------------------------------
STRATEGY_UNIVERSE=RELIANCE,INFY,HDFCBANK,TCS,ICICIBANK

# ----------------------------------------------------------
# Product Type
# MIS = Intraday (auto-squared off at 3:20 PM by broker)    ← RECOMMENDED for algo
# CNC = Delivery (positions carry to next trading day)
# ----------------------------------------------------------
PRODUCT_TYPE=MIS

# ----------------------------------------------------------
# Risk & Position Management
# ----------------------------------------------------------
MAX_POSITIONS=8
RISK_PER_TRADE_PCT=1.0
MAX_POSITION_PCT=10.0

# ----------------------------------------------------------
# AI Agent Settings (Gemini)
# Get key from: https://aistudio.google.com/apikey
# ----------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# ----------------------------------------------------------
# Telegram Alerts (optional)
# ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
